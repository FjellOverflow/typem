{
  "name": "typem",
  "version": "1.1.0",
  "private": true,
  "description": "Type out the list items as quickly as possible.",
  "homepage": "https://github.com/FjellOverflow/typem",
  "bugs": {
    "url": "https://github.com/FjellOverflow/typem/issues"
  },
  "license": "GPL-3.0-only",
  "author": "FjellOverflow",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p typecheck \"build-only {@}\" --",
    "preview": "vite build && vite preview",
    "test:unit": "vitest run",
    "test:unit:dev": "vitest",
    "test:e2e": "start-server-and-test preview http://localhost:4173 'cypress run --e2e'",
    "test:e2e:dev": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
    "build-only": "vite build",
    "typecheck": "vue-tsc --build --force",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "release": "eslint . && prettier --check src && commit-and-tag-version --sign"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tsconfig/node22": "^22.0.5",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/tsconfig": "^0.8.1",
    "@vueuse/core": "^14.1.0",
    "@vueuse/router": "^14.1.0",
    "baseline-browser-mapping": "^2.9.11",
    "caniuse-lite": "^1.0.30001761",
    "daisyui": "^5.5.14",
    "flag-icons": "^7.5.0",
    "lucide-vue-next": "^0.562.0",
    "shepherd.js": "^14.5.1",
    "tailwindcss": "^4.1.18",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-vue-components": "^30.0.0",
    "unplugin-vue-router": "^0.19.1",
    "vite": "^7.3.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-layouts": "^0.11.0",
    "vue-i18n": "^11.2.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.0.3",
    "@vitest/eslint-plugin": "1.1.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "commit-and-tag-version": "^12.6.1",
    "cypress": "^15.8.1",
    "eslint": "^9.39.2",
    "eslint-plugin-cypress": "^5.2.0",
    "eslint-plugin-vue": "^10.6.2",
    "jsdom": "^27.3.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "start-server-and-test": "^2.1.3",
    "typescript": "~5.9.3",
    "vitest": "^4.0.16",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4",
    "vue-tsc": "^3.1.8"
  }
}
