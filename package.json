{
  "name": "typem",
  "version": "1.1.1",
  "private": true,
  "description": "Type out the list items as quickly as possible.",
  "homepage": "https://github.com/FjellOverflow/typem",
  "bugs": {
    "url": "https://github.com/FjellOverflow/typem/issues"
  },
  "license": "GPL-3.0-only",
  "author": "FjellOverflow",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p typecheck \"build-only {@}\" --",
    "preview": "vite build && vite preview",
    "test:unit": "vitest run",
    "test:unit:dev": "vitest",
    "test:e2e": "start-server-and-test preview http://localhost:4173 'cypress run --e2e'",
    "test:e2e:dev": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
    "build-only": "vite build",
    "typecheck": "vue-tsc --build --force",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "release": "eslint . && prettier --check src && commit-and-tag-version --sign"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@tsconfig/node22": "^22.0.5",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "@vueuse/core": "^14.2.1",
    "@vueuse/router": "^14.2.1",
    "baseline-browser-mapping": "^2.10.23",
    "caniuse-lite": "^1.0.30001791",
    "daisyui": "^5.5.19",
    "flag-icons": "^7.5.0",
    "lucide-vue-next": "^1.0.0",
    "shepherd.js": "^15.2.2",
    "tailwindcss": "^4.2.4",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "unplugin-vue-router": "^0.19.2",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-layouts": "^0.11.0",
    "vue-i18n": "^11.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@vitest/eslint-plugin": "1.6.16",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.9",
    "commit-and-tag-version": "^12.7.1",
    "cypress": "^15.14.1",
    "eslint": "^10.2.1",
    "eslint-plugin-cypress": "^6.3.1",
    "eslint-plugin-vue": "^10.9.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.1.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "start-server-and-test": "^3.0.2",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "vue-tsc": "^3.2.7"
  }
}
